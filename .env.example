# ── Supabase (self-hosted en VPS Dokploy) ────────────────────────────────────
# URL pública del Kong gateway (se ve en Dokploy → Supabase → SUPABASE_PUBLIC_URL)
SUPABASE_URL=http://automation-supabase-c607de-46-202-171-141.traefik.me

# Service role key (Dokploy → Supabase env → SERVICE_ROLE_KEY)
# NUNCA exponer esta key al cliente. Solo se usa server-side.
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...service_role...

# ── Resend (email transaccional) ──────────────────────────────────────────────
# Generá una API key en: resend.com → API Keys
# Y verificá el dominio filmmakerstudio.com en resend.com → Domains antes de enviar.
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxx
RESEND_FROM_EMAIL=info@filmmakerstudio.com

# ── URL pública del sitio (para QR, OG tags, redirect callbacks) ──────────────
